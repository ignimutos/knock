{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [],
    "deny": [],
    "defaultMode": "acceptEdits",
    "skipDangerousModePermissionPrompt": true
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/permission-request-allow.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/fmt-after-write.sh"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "deno run --allow-read --allow-write --allow-env .claude/hooks/subagent-worktree-ledger.ts"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "deno run --allow-read --allow-write --allow-env .claude/hooks/subagent-worktree-ledger.ts"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "deno run --allow-read --allow-write --allow-env .claude/hooks/subagent-worktree-ledger.ts"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "deno run --allow-read --allow-write --allow-env .claude/hooks/subagent-worktree-ledger.ts"
          }
        ]
      }
    ]
  }
}
