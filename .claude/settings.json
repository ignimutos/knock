{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "ENABLE_TOOL_SEARCH": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "0"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "NotebookEdit",
      "Read",
      "Glob",
      "Grep",
      "LSP",
      "WebFetch",
      "WebSearch",
      "Monitor",
      "PowerShell",
      "Skill",
      "Agent",
      "AskUserQuestion",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ExitWorktree",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "TodoWrite",
      "CronCreate",
      "CronDelete",
      "CronList",
      "ToolSearch",
      "ListMcpResourcesTool",
      "ReadMcpResourceTool",
      "SendMessage",
      "TeamCreate",
      "TeamDelete",
      "TeamList",
      "mcp__puppeteer__*",
      "mcp__playwright__*",
      "mcp__github__*",
      "mcp__context7__*",
      "mcp__claude-mem__*"
    ],
    "deny": [],
    "defaultMode": "acceptEdits",
    "skipDangerousModePermissionPrompt": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/fmt.sh"
          },
          {
            "type": "command",
            "command": "python .claude/skills/test-architecture-guard/scripts/guard.py"
          }
        ]
      }
    ]
  }
}
